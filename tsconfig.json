{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@cubepay/shared-types": ["libs/shared-types/src/index.ts"],
      "@cubepay/queue": ["libs/queue/src/index.ts"],
      "@cubepay/crypto": ["libs/crypto/src/index.ts"],
      "@cubepay/auth": ["libs/auth/src/index.ts"],
      "@cubepay/logger": ["libs/logger/src/index.ts"]
    }
  }
}
