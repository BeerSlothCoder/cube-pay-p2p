{
  "name": "cubepay-backend",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "build:api": "nest build api",
    "build:oracle": "nest build oracle",
    "build:payment": "nest build payment",
    "build:blind-vault": "nest build blind-vault",
    "build:hsm-mock": "nest build hsm-mock",
    "start:api": "nest start api",
    "start:oracle": "nest start oracle",
    "start:payment": "nest start payment",
    "start:blind-vault": "nest start blind-vault",
    "start:hsm-mock": "nest start hsm-mock",
    "start:dev:api": "nest start --watch api",
    "start:dev:oracle": "nest start --watch oracle",
    "start:dev:payment": "nest start --watch payment",
    "start:dev:blind-vault": "nest start --watch blind-vault",
    "start:dev:hsm-mock": "nest start --watch hsm-mock",
    "start:dev:all": "concurrently \"npm run start:dev:api\" \"npm run start:dev:oracle\" \"npm run start:dev:payment\" \"npm run start:dev:blind-vault\" \"npm run start:dev:hsm-mock\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format": "prettier --write \"{src,apps,libs,test}/**/*.ts\""
  },
  "dependencies": {
    "@nestjs/bullmq": "^10.2.1",
    "@nestjs/common": "^10.3.10",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.3.10",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.10",
    "@nestjs/swagger": "^7.4.0",
    "@supabase/supabase-js": "^2.58.0",
    "@solana/web3.js": "^1.98.4",
    "bullmq": "^5.8.5",
    "ethers": "^5.7.2",
    "express-rate-limit": "^7.3.1",
    "h3-js": "^4.1.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jose": "^5.6.3",
    "nestjs-zod": "^3.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pkijs": "^3.2.4",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "shamirs-secret-sharing": "^2.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.2",
    "@nestjs/schematics": "^10.1.3",
    "@nestjs/testing": "^10.3.10",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.10",
    "@types/passport-jwt": "^4.0.1",
    "@types/qrcode": "^1.5.5",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  },
  "overrides": {
    "multer": "2.1.1",
    "lodash": "4.17.21"
  }
}
