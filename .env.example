# ─── CubePay Backend Environment Configuration ────────────────────────────────
# Copy this file to .env and fill in values.
# NEVER commit .env to git.

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:5175

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Must be >= 32 chars. Generate: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Internal service-to-service key (api → blind-vault)
# Generate: openssl rand -hex 32
INTERNAL_API_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ─── Database (Supabase) ──────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# ─── Oracle ───────────────────────────────────────────────────────────────────
# DEVELOPMENT ONLY — In production use HSM. Never commit real key.
ORACLE_PRIVATE_KEY=0x_your_dev_wallet_private_key_here
USE_HSM=false
HSM_MOCK_URL=http://localhost:3005

# ─── Blockchain RPC ───────────────────────────────────────────────────────────
EVM_RPC_URL=https://polygon-mumbai.g.alchemy.com/v2/YOUR_KEY
SOLANA_RPC_URL=https://api.devnet.solana.com
HEDERA_ACCOUNT_ID=0.0.xxxxx
HEDERA_PRIVATE_KEY=

# ─── Payments ─────────────────────────────────────────────────────────────────
REVOLUT_SECRET_KEY=sand_your_revolut_sandbox_key
REVOLUT_WEBHOOK_SECRET=your_revolut_webhook_signing_secret

# ─── KYC ──────────────────────────────────────────────────────────────────────
KYC_WEBHOOK_SECRET=your_sumsub_webhook_secret
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=

# ─── Regulatory Key (Public — safe to commit once generated) ──────────────────
# This is the RSA-4096 PUBLIC key used for client-side JWE encryption.
# Generated in air-gapped key ceremony. Private key is never here.
REGULATORY_PUBLIC_KEY_PEM=-----BEGIN PUBLIC KEY-----\nYOUR_RSA4096_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----

# ─── Service Ports ────────────────────────────────────────────────────────────
# API_PORT=3001         (public)
# PAYMENT_PORT=3003     (internal)
# VAULT_PORT=3004       (internal)
# HSM_MOCK_PORT=3005    (dev only)
# Oracle has NO HTTP port — queue only
