{
  "monorepo": true,
  "root": "apps/api",
  "sourceRoot": "apps/api/src",
  "compilerOptions": {
    "webpack": false,
    "tsConfigPath": "tsconfig.json"
  },
  "projects": {
    "api": {
      "type": "application",
      "root": "apps/api",
      "entryFile": "src/main",
      "sourceRoot": "apps/api/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api/tsconfig.app.json"
      }
    },
    "oracle": {
      "type": "application",
      "root": "apps/oracle",
      "entryFile": "src/main",
      "sourceRoot": "apps/oracle/src",
      "compilerOptions": {
        "tsConfigPath": "apps/oracle/tsconfig.app.json"
      }
    },
    "payment": {
      "type": "application",
      "root": "apps/payment",
      "entryFile": "src/main",
      "sourceRoot": "apps/payment/src",
      "compilerOptions": {
        "tsConfigPath": "apps/payment/tsconfig.app.json"
      }
    },
    "blind-vault": {
      "type": "application",
      "root": "apps/blind-vault",
      "entryFile": "src/main",
      "sourceRoot": "apps/blind-vault/src",
      "compilerOptions": {
        "tsConfigPath": "apps/blind-vault/tsconfig.app.json"
      }
    },
    "hsm-mock": {
      "type": "application",
      "root": "apps/hsm-mock",
      "entryFile": "src/main",
      "sourceRoot": "apps/hsm-mock/src",
      "compilerOptions": {
        "tsConfigPath": "apps/hsm-mock/tsconfig.app.json"
      }
    },
    "shared-types": {
      "type": "library",
